#!/usr/bin/env python3
"""Seed (or refresh) every benchmark dashboard template into D1.

Templates are DB-only -- there is no code seed -- so a curated template has to be
written to the `dashboard_templates` table directly. This discovers every
`benchmarks/*/template.json` and upserts each one (delete-by-name then insert),
status='approved' so they show in the New Dashboard grid immediately.

This is the generic path; `slopcodebench/bin/scb-insert-template` delegates here
for the single SlopCodeBench template.

Usage:
  bin/seed-benchmark-templates                  # all templates, desktop d1-shim
  bin/seed-benchmark-templates swebench         # only benchmarks/swebench/template.json
  D1_URL=http://127.0.0.1:9001 AUTHOR_ID=dev-desktop bin/seed-benchmark-templates

For a remote/cloud control plane, export a template instead via the templates API
from an existing dashboard (POST /templates) -- direct INSERT is the local/curated
path.
"""
import datetime
import json
import os
import pathlib
import sys
import urllib.request
import uuid

D1_URL = os.environ.get("D1_URL", "http://127.0.0.1:9001")
AUTHOR_ID = os.environ.get("AUTHOR_ID", "dev-desktop")
AUTHOR_NAME = os.environ.get("AUTHOR_NAME", "OrcaBot")

# benchmarks/ root (this file lives in benchmarks/bin/).
ROOT = pathlib.Path(__file__).resolve().parent.parent


def q(sql, params):
    req = urllib.request.Request(
        D1_URL.rstrip("/") + "/query",
        data=json.dumps({"sql": sql, "params": params}).encode(),
        headers={"Content-Type": "application/json"},
    )
    return json.load(urllib.request.urlopen(req))


def discover(filter_dirs):
    """Return the template.json paths to seed, optionally limited to named dirs."""
    if filter_dirs:
        paths = []
        for name in filter_dirs:
            p = ROOT / name / "template.json"
            if not p.exists():
                sys.exit(f"no template.json in benchmarks/{name}/")
            paths.append(p)
        return paths
    return sorted(ROOT.glob("*/template.json"))


def upsert(tpl):
    tid = str(uuid.uuid4())
    now = datetime.datetime.utcnow().isoformat()
    q("DELETE FROM dashboard_templates WHERE name = ?", [tpl["name"]])
    q(
        """INSERT INTO dashboard_templates
           (id,name,description,category,author_id,author_name,items_json,edges_json,
            viewport_json,setup_guide,item_count,is_featured,use_count,status,created_at,updated_at)
           VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""",
        [
            tid, tpl["name"], tpl["description"], tpl.get("category", "coding"),
            AUTHOR_ID, AUTHOR_NAME,
            json.dumps(tpl["items"]), json.dumps(tpl["edges"]),
            json.dumps(tpl.get("viewport")), tpl.get("setupGuide"), len(tpl["items"]),
            1, 0, "approved", now, now,
        ],
    )
    return tid


def main():
    paths = discover(sys.argv[1:])
    # Ensure the setup_guide column exists (idempotent) so older DBs accept the insert.
    try:
        q("ALTER TABLE dashboard_templates ADD COLUMN setup_guide TEXT", [])
    except Exception:
        pass
    for path in paths:
        tpl = json.loads(path.read_text())
        tid = upsert(tpl)
        print(f"seeded '{tpl['name']}' (id={tid}) from {path.relative_to(ROOT.parent)}")
    print(f"done: {len(paths)} template(s) -> {D1_URL}")


if __name__ == "__main__":
    main()
