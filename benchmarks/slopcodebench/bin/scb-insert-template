#!/usr/bin/env python3
"""Insert (or refresh) the SlopCodeBench Runner dashboard template into D1.

Templates are DB-only -- there is no code seed -- so a curated template has to be
written to the `dashboard_templates` table directly. This reads the sibling
template.json and upserts it (delete-by-name then insert), status='approved' so
it shows in the New Dashboard grid immediately.

Usage:
  bin/scb-insert-template                       # desktop d1-shim on 127.0.0.1:9001
  D1_URL=http://127.0.0.1:9001 AUTHOR_ID=dev-desktop bin/scb-insert-template

For a remote/cloud control plane, export the template instead via the templates
API from an existing dashboard (POST /templates) -- direct INSERT is the
local/curated path.
"""
import json, os, urllib.request, uuid, datetime, pathlib

D1_URL = os.environ.get("D1_URL", "http://127.0.0.1:9001")
AUTHOR_ID = os.environ.get("AUTHOR_ID", "dev-desktop")
AUTHOR_NAME = os.environ.get("AUTHOR_NAME", "OrcaBot")

here = pathlib.Path(__file__).resolve().parent
tpl = json.loads((here.parent / "template.json").read_text())


def q(sql, params):
    req = urllib.request.Request(
        D1_URL.rstrip("/") + "/query",
        data=json.dumps({"sql": sql, "params": params}).encode(),
        headers={"Content-Type": "application/json"},
    )
    return json.load(urllib.request.urlopen(req))


tid = str(uuid.uuid4())
now = datetime.datetime.utcnow().isoformat()
q("DELETE FROM dashboard_templates WHERE name = ?", [tpl["name"]])
q(
    """INSERT INTO dashboard_templates
       (id,name,description,category,author_id,author_name,items_json,edges_json,
        viewport_json,item_count,is_featured,use_count,status,created_at,updated_at)
       VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""",
    [
        tid, tpl["name"], tpl["description"], tpl.get("category", "coding"),
        AUTHOR_ID, AUTHOR_NAME,
        json.dumps(tpl["items"]), json.dumps(tpl["edges"]),
        json.dumps(tpl.get("viewport")), len(tpl["items"]),
        1, 0, "approved", now, now,
    ],
)
print(f"inserted '{tpl['name']}' (id={tid}) into {D1_URL}")
