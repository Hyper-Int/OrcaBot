{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "remote": {
    "urls": ["http://localhost:*"]
  },
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" }
      ]
    }
  ]
}
