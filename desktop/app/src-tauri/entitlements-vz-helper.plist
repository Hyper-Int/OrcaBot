<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- vz-helper is the process that calls Virtualization.framework to run the
         sandbox VM, so it needs the virtualization entitlement on its own
         signature (entitlements are per-binary). -->
    <key>com.apple.security.virtualization</key>
    <true/>
</dict>
</plist>
